{
  "containerDefinitions": [
    {
      "name": "yodlee-ops-container",
      "portMappings": [
        {
          "name": "yodlee-ops-container-8080-tcp",
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/yodlee-ops-app-task",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "environment": [
        { "name": "KAFKA_BROKERS", "value": "boot-fhjyxqxf.c1.kafka-serverless.us-east-1.amazonaws.com:9098" }
      ]
    }
  ],
  "family": "yodlee-ops-app-task",
  "taskRoleArn": "arn:aws:iam::938864279852:role/yodlee-ops-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::938864279852:role/yodlee-ops-ecs-task-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}